    - '// @input float autoReturnSeconds {"hint":"Seconds of no interaction before easing back to the start orientation. 0 = never.", "widget":"slider", "min":0, "max":10, "step":0.5}'
    - '// @input float returnSpeed = 3 {"hint":"How fast returnToRest()/auto-return eases home.", "widget":"slider", "min":0.5, "max":8, "step":0.25}'
    - '// @input float fallbackDragRadiansPerCm = 0.12 {"hint":"Fallback rotation scale when no surface hit point is available.", "widget":"slider", "min":0.01, "max":0.45, "step":0.01}'
    - '// @input bool lockAxisX {"hint":"Block spin about the world X axis (pitch / tilt up-down)."}'
    - '// @input bool lockAxisY {"hint":"Block spin about the world Y axis (yaw / horizontal spin)."}'
    - '// @input bool lockAxisZ {"hint":"Block spin about the world Z axis (roll / sideways tumble)."}'
