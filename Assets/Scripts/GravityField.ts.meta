  InputLines:
    - '// @input SceneObject earthObject {"hint":"Optional Earth object. If unset, a generated flat shaded Earth is used."}'
    - '// @input SceneObject moonObject {"hint":"Optional Moon object. If unset, a generated flat shaded Moon is used."}'
    - '// @input bool useModelPositions = true {"hint":"When on, the field samples the live Earth/Moon transforms so orbital motion deforms the visualization."}'
    - '// @input bool earthAxialMotionEnabled = true {"hint":"When on, the Earth spins on its tilted axis. The 23.4 degree tilt itself is always applied."}'
    - '// @input bool moonOrbitMotionEnabled = true {"hint":"When on, moves the Moon model around Earth."}'
    - '// @input bool moonSynchronousRotationEnabled = true {"hint":"When on, the Moon is tidally locked: the same face always points toward Earth."}'
    - '// @input float simulatedHoursPerSecond = 8 {"hint":"Simulated hours per real second for celestial motion toggles. 8.0 makes a Moon orbit complete in ~80 s.", "widget":"slider", "min":0.05, "max":48, "step":0.05}'
    - '// @input float motionRebuildInterval = 0.33 {"hint":"Minimum seconds between field rebuilds while the Moon orbit is animated.", "widget":"slider", "min":0.05, "max":1, "step":0.05}'
    - '// @input float earthMass = 18 {"hint":"Relative Earth mass", "widget":"slider", "min":1, "max":30, "step":0.5}'
    - '// @input float moonMass = 2 {"hint":"Moon mass multiplier. 1 means the real Earth/Moon mass ratio.", "widget":"slider", "min":0.25, "max":8, "step":0.25}'
    - '// @input float planeSize = 18 {"hint":"Width/depth of the sampled plane in centimeters", "widget":"slider", "min":8, "max":28, "step":1}'
    - '// @input float arrowResolution = 7 {"hint":"Number of arrows per side on the flat vector plane", "widget":"slider", "min":5, "max":17, "step":1}'
    - '// @input float wellResolution = 18 {"hint":"Resolution for scalar contours and well guide curves", "widget":"slider", "min":8, "max":28, "step":1}'
    - '// @input float fieldLineCount = 72 {"hint":"Number of integrated gravity field lines", "widget":"slider", "min":24, "max":120, "step":4}'
    - '// @input float fieldLineSteps = 168 {"hint":"Integration steps per field line", "widget":"slider", "min":36, "max":240, "step":4}'
    - '// @input float softening = 0.85 {"hint":"Body-relative softening multiplier. Keeps lines stable near bodies.", "widget":"slider", "min":0.1, "max":2, "step":0.05}'
    - '// @input float arrowScale = 0.22 {"hint":"Visual arrow length scale", "widget":"slider", "min":0.05, "max":1.2, "step":0.05}'
    - '// @input float arrowWidth = 0.04 {"hint":"Arrow shaft width", "widget":"slider", "min":0.02, "max":0.35, "step":0.01}'
    - '// @input float lineWidth = 0.08 {"hint":"Tube diameter for gravity field and same-potential curves", "widget":"slider", "min":0.025, "max":0.22, "step":0.005}'
    - '// @input float artemisTrajectoryScale = 2.65 {"hint":"Display-only scale multiplier for the Artemis II trajectory and Moon distance. Body model sizes stay constant.", "widget":"slider", "min":0.75, "max":6, "step":0.05}'
    - '// @input float artemisEarthClearance = 0.65 {"hint":"Minimum visual gap between the Artemis II path and the visible Earth model.", "widget":"slider", "min":0, "max":1.5, "step":0.05}'
    - '// @input float wellDepth = 2.4 {"hint":"How far the scalar gravity well falls along local Y. Depth scales with body mass so Earth dominates the Moon.", "widget":"slider", "min":0.15, "max":6, "step":0.05}'
    - '// @input Asset.Material material {"hint":"Flat/toon material cloned for generated gravity meshes"}'
    - '// @input Asset.Material artemisPlannedMaterial {"hint":"Dedicated Artemis planned dotted path material. Use a flat unlit material; do not share with other gravity visuals."}'
    - '// @input Asset.Material artemisCompletionMaterial {"hint":"Dedicated Artemis completion material using ArtemisPathProgress.js. Exposes BaseColor, Progress, and Feather."}'
    - '// @input Asset.Material artemisCursorMaterial {"hint":"Dedicated Artemis current-position indicator material. Use a flat unlit overlay material."}'
    - '// @input vec4 artemisCursorColor = {0.92,1,1,1} {"hint":"Color for the Artemis current-position indicator.", "widget":"color"}'
    - '// @input float initialStage = 2 {"hint":"Standalone preview stage used when the component wakes up.", "widget":"combobox", "values":[{"label":"Bodies", "value":0}, {"label":"Arrows", "value":1}, {"label":"Field Lines", "value":2}]}'
