  InputLines:
    - '// @input SceneObject earthObject {"hint":"Earth SceneObject. The script reads its world position into the EarthPos uniform."}'
    - '// @input SceneObject moonObject {"hint":"Moon SceneObject. The script reads its world position into the MoonPos uniform."}'
    - '// @input Asset.Material planeMaterial {"hint":"Material instanced from GravityFieldPlane.mat. The script clones it so multiple plane instances stay independent."}'
    - '// @input float planeSize = 56 {"hint":"Plane width/depth in cm.", "widget":"slider", "min":6, "max":72, "step":0.5}'
    - '// @input float resolution = 56 {"hint":"Vertices per side of the plane mesh. Higher = smoother well and contours; 96 is a safe Spectacles default.", "widget":"slider", "min":24, "max":192, "step":4}'
    - '// @input float earthMass = 18 {"hint":"Earth mass (relative units).", "widget":"slider", "min":1, "max":30, "step":0.5}'
    - '// @input float moonMass = 4 {"hint":"Moon mass multiplier vs. real Earth/Moon ratio.", "widget":"slider", "min":0.25, "max":8, "step":0.25}'
    - '// @input float softening = 1.5 {"hint":"Softening radius. Caps the 1/r singularity at body centers.", "widget":"slider", "min":0.05, "max":1.5, "step":0.05}'
    - '// @input float wellDepth = 3.9 {"hint":"Vertical scale of the gravity well displacement.", "widget":"slider", "min":0.05, "max":4, "step":0.05}'
    - '// @input float depthScale = 0.26 {"hint":"Multiplier inside the shader; tune with wellDepth for the visual look.", "widget":"slider", "min":0.01, "max":0.5, "step":0.01}'
    - '// @input float contourCount = 5 {"hint":"Number of iso-potential contour rings drawn across the plane.", "widget":"slider", "min":2, "max":24, "step":0.5}'
    - '// @input float contourThickness = 0.08 {"hint":"Contour line half-width (relative to ring spacing).", "widget":"slider", "min":0, "max":0.5, "step":0.01}'
    - '// @input float flowSpeed {"hint":"Animation speed for the flow stripes along the field direction.", "widget":"slider", "min":0, "max":4, "step":0.05}'
    - '// @input float flowScale = 1.1 {"hint":"Spatial frequency of the flow stripes.", "widget":"slider", "min":0.2, "max":8, "step":0.1}'
    - '// @input float opacityScale = 1 {"hint":"Overall plane opacity scale.", "widget":"slider", "min":0, "max":1, "step":0.05}'
    - '// @input vec4 colorLow = {0.018,0.024,0.07,1} {"hint":"Low-potential heatmap color (far from masses).", "widget":"color"}'
    - '// @input vec4 colorHigh = {0.07,0.09,0.18,1} {"hint":"High-potential heatmap color (near masses).", "widget":"color"}'
    - '// @input vec4 contourColor = {1,0.25,0.18,0.98} {"hint":"Contour ring color (alpha controls strength).", "widget":"color"}'
    - '// @input vec4 earthTint = {1,0.28,0.22,1} {"hint":"Tint applied where Earth dominates the field.", "widget":"color"}'
    - '// @input vec4 moonTint = {0.22,0.6,1,1} {"hint":"Tint applied where the Moon dominates the field.", "widget":"color"}'
    - '// @input vec4 fieldLineColor = {0.36,0.44,1,0.92} {"hint":"Field-line overlay color.", "widget":"color"}'
    - '// @input float fieldLineDensity = 1.25 {"hint":"Field line density in local plane space.", "widget":"slider", "min":0.1, "max":2.5, "step":0.05}'
    - '// @input float fieldLineWidth = 0.09 {"hint":"Field line width relative to spacing.", "widget":"slider", "min":0.01, "max":0.25, "step":0.005}'
    - '// @input bool useSurfaceTubeGlyphs = true {"hint":"Draw real straight tube glyphs on the deformed gravity surface."}'
    - '// @input Asset.Material surfaceTubeMaterial {"hint":"Material for the surface-following tube glyph mesh."}'
    - '// @input float tubeColumns = 7 {"hint":"Tube glyph columns across the gravity plane.", "widget":"slider", "min":5, "max":35, "step":1}'
    - '// @input float tubeRows = 11 {"hint":"Tube glyph rows across the gravity plane.", "widget":"slider", "min":5, "max":27, "step":1}'
    - '// @input float tubeLengthSegments = 3 {"hint":"Number of points along each straight projected glyph; higher follows the well deformation more smoothly.", "widget":"slider", "min":2, "max":10, "step":1}'
    - '// @input float tubeRadialSegments = 4 {"hint":"Radial segments per tube.", "widget":"slider", "min":4, "max":12, "step":1}'
    - '// @input float tubeLength = 1.35 {"hint":"Projected straight glyph length in X/Z plane.", "widget":"slider", "min":0.05, "max":3, "step":0.05}'
    - '// @input float tubeRadius = 0.045 {"hint":"Tube radius.", "widget":"slider", "min":0.01, "max":0.22, "step":0.005}'
    - '// @input float tubeSurfaceLift = 0.055 {"hint":"Lift above the deformed gravity plane to avoid z-fighting.", "widget":"slider", "min":-0.5, "max":0.8, "step":0.005}'
    - '// @input float tubeRebuildFps = 4 {"hint":"How often dynamic glyph geometry is rebuilt while bodies move.", "widget":"slider", "min":1, "max":30, "step":1}'
