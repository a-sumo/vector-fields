  InputLines:
    - '// @input SceneObject earthObject {"hint":"Earth SceneObject. The script reads its world position into the EarthPos uniform."}'
    - '// @input SceneObject moonObject {"hint":"Moon SceneObject. The script reads its world position into the MoonPos uniform."}'
    - '// @input Asset.Material planeMaterial {"hint":"Material instanced from GravityFieldPlane.mat. The script clones it so multiple plane instances stay independent."}'
    - '// @input float planeSize = 56 {"hint":"Plane width/depth in cm.", "widget":"slider", "min":6, "max":72, "step":0.5}'
    - '// @input float resolution = 128 {"hint":"Vertices per side of the plane mesh. Higher = smoother well and contours; 96 is a safe Spectacles default.", "widget":"slider", "min":24, "max":192, "step":4}'
    - '// @input float earthMass = 18 {"hint":"Earth mass (relative units).", "widget":"slider", "min":1, "max":30, "step":0.5}'
    - '// @input float moonMass = 2 {"hint":"Moon mass multiplier vs. real Earth/Moon ratio.", "widget":"slider", "min":0.25, "max":8, "step":0.25}'
    - '// @input float softening = 0.35 {"hint":"Softening radius. Caps the 1/r singularity at body centers.", "widget":"slider", "min":0.05, "max":1.5, "step":0.05}'
    - '// @input float wellDepth = 1 {"hint":"Vertical scale of the gravity well displacement.", "widget":"slider", "min":0.05, "max":4, "step":0.05}'
    - '// @input float depthScale = 0.18 {"hint":"Multiplier inside the shader; tune with wellDepth for the visual look.", "widget":"slider", "min":0.01, "max":0.5, "step":0.01}'
    - '// @input float contourCount = 9 {"hint":"Number of iso-potential contour rings drawn across the plane.", "widget":"slider", "min":2, "max":24, "step":0.5}'
    - '// @input float contourThickness = 0.18 {"hint":"Contour line half-width (relative to ring spacing).", "widget":"slider", "min":0, "max":0.5, "step":0.01}'
    - '// @input float flowSpeed = 0.6 {"hint":"Animation speed for the flow stripes along the field direction.", "widget":"slider", "min":0, "max":4, "step":0.05}'
    - '// @input float flowScale = 1.6 {"hint":"Spatial frequency of the flow stripes.", "widget":"slider", "min":0.2, "max":8, "step":0.1}'
    - '// @input float opacityScale = 0.92 {"hint":"Overall plane opacity scale.", "widget":"slider", "min":0, "max":1, "step":0.05}'
    - '// @input vec4 colorLow = {0.12,0.36,1,1} {"hint":"Low-potential heatmap color (far from masses).", "widget":"color"}'
    - '// @input vec4 colorHigh = {1,0.08,0.1,1} {"hint":"High-potential heatmap color (near masses).", "widget":"color"}'
    - '// @input vec4 contourColor = {1,0.16,0.22,0.98} {"hint":"Contour ring color (alpha controls strength).", "widget":"color"}'
    - '// @input vec4 earthTint = {1,0.28,0.22,1} {"hint":"Tint applied where Earth dominates the field.", "widget":"color"}'
    - '// @input vec4 moonTint = {0.22,0.6,1,1} {"hint":"Tint applied where the Moon dominates the field.", "widget":"color"}'
    - '// @input vec4 fieldLineColor = {0.3,0.62,1,0.78} {"hint":"Field-line overlay color.", "widget":"color"}'
    - '// @input vec4 arrowColor = {1,0.9,0.96,0.7} {"hint":"Arrow overlay color.", "widget":"color"}'
    - '// @input float fieldLineDensity = 0.82 {"hint":"Field line density in local plane space.", "widget":"slider", "min":0.1, "max":2.5, "step":0.05}'
    - '// @input float fieldLineWidth = 0.065 {"hint":"Field line width relative to spacing.", "widget":"slider", "min":0.01, "max":0.25, "step":0.005}'
    - '// @input float arrowSpacing = 6.4 {"hint":"Spacing between shader-drawn arrows.", "widget":"slider", "min":1.2, "max":9, "step":0.1}'
    - '// @input float arrowScale = 0.34 {"hint":"Size of each shader-drawn arrow within its grid cell.", "widget":"slider", "min":0.08, "max":1.1, "step":0.05}'
