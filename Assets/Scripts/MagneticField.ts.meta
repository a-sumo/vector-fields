    - '// @input float _gridSpacing = 1 {"hint":"Spacing between tube start positions", "widget":"slider", "min":0.1, "max":5, "step":0.1}'
    - '// @input float _stepSize = 0.1 {"hint":"Step size for field integration", "widget":"slider", "min":0.01, "max":0.5, "step":0.01}'
    - '// @input float _fieldStrength = 1 {"hint":"Field strength multiplier", "widget":"slider", "min":0.1, "max":10, "step":0.1}'
    - '// @input float _flowSpeed = 2 {"hint":"Speed at which tubes flow along field lines", "widget":"slider", "min":0, "max":50, "step":0.5}'
    - '// @input SceneObject magnet1 {"hint":"First magnet object - Y rotation determines N/S orientation"}'
    - '// @input SceneObject magnet2 {"hint":"Second magnet object - Y rotation determines N/S orientation"}'
    - '// @input Asset.Material material {"hint":"Material with MagneticFieldTubesShader.js"}'
