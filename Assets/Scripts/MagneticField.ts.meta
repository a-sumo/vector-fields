  InputLines:
    - '// @input float _maxVertexCount = 40000 {"hint":"Maximum vertex count budget - geometry adapts to stay below this", "widget":"slider", "min":10000, "max":100000, "step":5000}'
    - '// @input float _tubeMode {"hint":"Trails: flowing tubes, Arrows: static oriented", "widget":"combobox", "values":[{"label":"Trails", "value":0}, {"label":"Arrows", "value":2}]}'
    - '// @input float _desiredLengthSegments = 32 {"hint":"Desired segments along tube length (may be reduced to fit vertex budget)", "widget":"slider", "min":2, "max":64, "step":2}'
