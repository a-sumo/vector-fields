  InputLines:
    - '// @input Asset.Material material {"hint":"Optional material. Use an OrientedTubeGlyph material for per-tube flat palette colors."}'
    - '// @input SceneObject fieldSourceObject {"hint":"Optional source object exposing sampleTubeGlyphField(x,z,time), such as GravityField.gravityApi or CarFlowStreamlines.windApi."}'
    - '// @input float fieldSourceMode {"hint":"Analytical uses the local animated presets. Source modes sample a sibling GravityField or CarFlowStreamlines API.", "widget":"combobox", "values":[{"label":"Analytical", "value":0}, {"label":"Gravity Source", "value":1}, {"label":"Car Wind Source", "value":2}]}'
    - '// @input bool syncLayoutFromSource = true {"hint":"When a source exposes planeWidth/planeDepth, keep this glyph grid aligned to that source."}'
    - '// @input bool syncTransformFromSource = true {"hint":"When a source object is provided, copy its world position/rotation/scale so this is a true alternate renderer for the same slice."}'
    - '// @input float dataPlane {"hint":"Geometry plane. Gravity/analytical fields use X/Z. Car-flow slices use X/Y.", "widget":"combobox", "values":[{"label":"X/Z plane", "value":0}, {"label":"X/Y plane", "value":1}]}'
    - '// @input float normalLift = 0.035 {"hint":"Small offset along the plane normal to avoid z-fighting with the source slice.", "widget":"slider", "min":-1, "max":1, "step":0.005}'
    - '// @input float fieldPreset {"widget":"combobox", "values":[{"label":"Expansion", "value":0}, {"label":"Contraction", "value":1}, {"label":"Curl", "value":2}, {"label":"Saddle", "value":3}, {"label":"Uniform", "value":4}]}'
    - '// @input float planeWidth = 24 {"widget":"slider", "min":2, "max":80, "step":0.5}'
    - '// @input float planeDepth = 14 {"widget":"slider", "min":2, "max":60, "step":0.5}'
    - '// @input float columns = 13 {"widget":"slider", "min":3, "max":33, "step":1}'
    - '// @input float rows = 9 {"widget":"slider", "min":3, "max":25, "step":1}'
    - '// @input float tubeLength = 0.82 {"widget":"slider", "min":0.08, "max":3.5, "step":0.02}'
    - '// @input float tubeRadius = 0.055 {"widget":"slider", "min":0.01, "max":0.35, "step":0.005}'
    - '// @input float radialSegments = 7 {"widget":"slider", "min":4, "max":14, "step":1}'
    - '// @input float fieldScale = 1 {"widget":"slider", "min":0, "max":2, "step":0.05}'
    - '// @input float animationSpeed = 0.45 {"widget":"slider", "min":0, "max":2, "step":0.05}'
    - '// @input float _colorMap = 17 {"hint":"Matplotlib-style colormap for tube magnitude/intensity.", "widget":"combobox", "values":[{"label":"jet", "value":13}, {"label":"viridis", "value":17}, {"label":"plasma", "value":18}]}'
    - '// @input float _colorMapScale = 1 {"hint":"Multiplies the normalized value before sampling the selected color gradient.", "widget":"slider", "min":0.05, "max":4, "step":0.01}'
    - '// @input float _colorMapOffset {"hint":"Adds to the normalized value before sampling the selected color gradient.", "widget":"slider", "min":-1, "max":1, "step":0.01}'
    - '// @input float magnitudeAlpha {"hint":"0 keeps tubes opaque. Higher values make magnitude affect alpha.", "widget":"slider", "min":0, "max":1, "step":0.01}'
    - '// @input float renderOrder = 42 {"widget":"slider", "min":0, "max":120, "step":1}'
    - '// @input float rebuildFps = 20 {"widget":"slider", "min":1, "max":60, "step":1}'
