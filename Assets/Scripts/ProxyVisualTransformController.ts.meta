  InputLines:
    - '// @input SceneObject menuRoot {"hint":"Menu root used as the docking reference. Empty searches for Story Chapter Guide UI."}'
    - '// @input SceneObject directorRoot {"hint":"Story Step Director root that reports the active visual root."}'
    - '// @input SceneObject cameraRoot {"hint":"Optional camera fallback when no menu root is available."}'
    - '// @input vec3 unfoldedDockOffset = {0,14,0.6} {"hint":"Menu-local dock offset while the guide is unfolded."}'
    - '// @input vec3 foldedDockOffset = {17.1,12.2,0.6} {"hint":"Menu-local dock offset while the guide is folded."}'
    - '// @input vec3 dockScale = {4.8,4.8,4.8} {"hint":"Local scale used when the proxy returns to its dock."}'
    - '// @input bool dockUnderActiveVisual = true {"hint":"Dock the proxy under the active visual instead of beside the menu."}'
    - '// @input float proxyDockPlacement {"hint":"Spatial placement language for the proxy dock.", "widget":"combobox", "values":[{"label":"Auto by active visual", "value":0}, {"label":"Tabletop / low plane", "value":1}, {"label":"Hand reach / head-height", "value":2}, {"label":"Distance cursor reach", "value":3}]}'
    - '// @input float visualDockGapCm = 8 {"hint":"Vertical gap below the active visual bounds.", "widget":"slider", "min":2, "max":28, "step":1}'
    - '// @input float visualDockTowardUserCm = 18 {"hint":"How far the proxy is pulled toward the camera from the active visual bounds, so it fronts the visual.", "widget":"slider", "min":0, "max":36, "step":1}'
    - '// @input float visualDockScaleFromBounds = 0.1 {"hint":"How much active visual size contributes to the proxy dock scale.", "widget":"slider", "min":0.02, "max":0.24, "step":0.01}'
    - '// @input float minVisualDockScaleMultiplier = 0.7 {"hint":"Minimum multiplier applied to dockScale when adapting to the active visual bounds.", "widget":"slider", "min":0.45, "max":1.4, "step":0.05}'
    - '// @input float maxVisualDockScaleMultiplier = 1.45 {"hint":"Maximum multiplier applied to dockScale when adapting to the active visual bounds.", "widget":"slider", "min":0.8, "max":2.4, "step":0.05}'
    - '// @input float dockSmoothing = 12 {"hint":"How quickly the proxy plane lands back on the dock.", "widget":"slider", "min":1, "max":30, "step":0.5}'
    - '// @input float dockTweenSeconds = 0.38 {"hint":"Seconds used when toggling the proxy inactive and returning it to dock.", "widget":"slider", "min":0.12, "max":1.2, "step":0.02}'
    - '// @input bool hideWhenNoActiveVisual {"hint":"Hide the proxy plane when no transformable visual is active."}'
    - '// @input bool autoActivateOnVisualSelected = true {"hint":"Automatically activate the proxy as soon as a transformable visual is selected."}'
    - '// @input float autoActivateReadyFrames = 3 {"hint":"Frames that the selected visual must have stable measurable bounds before auto-activating the proxy.", "widget":"slider", "min":1, "max":8, "step":1}'
    - '// @input float activationBlinkSeconds = 2.5 {"hint":"Seconds that the proxy softly blinks after activation. Set to 0 to disable the activation blink.", "widget":"slider", "min":0, "max":6, "step":0.1}'
    - '// @input bool driveScale = true {"hint":"Apply proxy scale changes to the active visual root."}'
    - '// @input bool driveRotation = true {"hint":"Apply proxy rotation changes to the active visual root."}'
