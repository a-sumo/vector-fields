  InputLines:
    - '// @input SceneObject motionFieldRoot {"hint":"Planar motion field rig."}'
    - '// @input SceneObject vectorFieldRoot {"hint":"Theory vector field rig."}'
    - '// @input SceneObject magneticFieldRoot {"hint":"Magnetic field example rig."}'
    - '// @input SceneObject gravityFieldRoot {"hint":"Gravity field example rig."}'
    - '// @input SceneObject windGlobeRoot {"hint":"Wind globe example rig."}'
    - '// @input bool applyOnStart {"hint":"Stage a step at startup when the director runs without the main guide."}'
    - '// @input float initialStep {"hint":"Initial step index when applyOnStart is enabled.", "widget":"slider", "min":0, "max":2, "step":1}'
    - '// @input SceneObject cameraRoot {"hint":"Optional head/camera anchor for menu-selected front placement. Empty searches for Camera Object."}'
    - '// @input SceneObject menuRoot {"hint":"Menu root used as the base transform for analytical field placement. Empty searches for Story Chapter Guide UI."}'
    - '// @input bool controlContentRoots = true {"hint":"Enable the real content roots associated with the selected story step."}'
    - '// @input float mainExperienceRenderOrder {"hint":"Render-order floor for active field/example visuals, keeping the main experience above the story guide when they overlap.", "widget":"slider", "min":0, "max":900, "step":1}'
    - '// @input float settleSeconds = 1.25 {"hint":"Keep applying briefly after startup so other setup scripts settle first."}'
    - '// @input float viewPlaneMode {"hint":"Reference frame used by gravity, magnetism, and wind examples.", "widget":"combobox", "values":[{"label":"Floor plane", "value":0}, {"label":"Front plane", "value":1}]}'
    - '// @input bool calibrateReferenceOnStart {"hint":"Ask for the shared reference-frame calibration on first start."}'
    - '// @input bool useReferenceCalibrationForExamples {"hint":"Use StageCalibration/SnapToStage for real-world examples. Usually off; front placement is the stable default."}'
    - '// @input bool useExampleProxySlots {"hint":"Use the C03 scaffold proxy slots as the default staging positions for real-world examples."}'
    - '// @input bool useFrontPlacementForAllVisuals = true {"hint":"Place each active visual root once in front of the user, leveled to world +Y, ignoring calibration/proxy slots."}'
    - '// @input bool resetDefaultStanceNow {"hint":"Set true in Inspector to put the active visual back into its default front-facing stance."}'
    - '// @input float initialExampleField {"hint":"Initial real-world example when the examples step is opened at startup.", "widget":"combobox", "values":[{"label":"Gravity", "value":0}, {"label":"Magnetism", "value":1}, {"label":"Wind", "value":2}, {"label":"Aerodynamics", "value":3}]}'
    - '// @input float initialTheoryFieldMode {"hint":"Initial theory field mode when the theory step is opened at startup.", "widget":"combobox", "values":[{"label":"Expansion", "value":0}, {"label":"Contraction", "value":1}, {"label":"Curl", "value":2}, {"label":"Motion", "value":3}]}'
    - '// @input float initialVectorColorMap = 18 {"hint":"Initial cube VectorField color map for theory modes.", "widget":"combobox", "values":[{"label":"jet", "value":13}, {"label":"viridis", "value":17}, {"label":"plasma", "value":18}]}'
    - '// @input float vectorColorMapScale = 1 {"hint":"Color-gradient scale for cube VectorField theory modes.", "widget":"slider", "min":0.05, "max":4, "step":0.01}'
    - '// @input float vectorColorMapOffset {"hint":"Color-gradient offset for cube VectorField theory modes.", "widget":"slider", "min":-1, "max":1, "step":0.01}'
    - '// @input vec3 theoryVectorFrontOffset = {0,0,-50} {"hint":"Camera-relative placement for the real VectorField in the theory chapter."}'
    - '// @input vec3 analyticalTabletopOffset = {0,-32,18} {"hint":"Menu-relative placement for Motion Field Root in analytical modes. X = menu right, Y = menu up/down, Z = toward user from the menu plane."}'
    - '// @input vec3 analyticalVectorFieldOffset = {0,-24,18} {"hint":"Menu-relative placement for Vector Field Examples Root in analytical modes. Separate from the motion plane because this root has a different pivot/bounds."}'
    - '// @input float analyticalTabletopTiltDegrees = 10 {"hint":"Tilt analytical tabletop fields toward the user in degrees. 0 keeps the plane normal exactly world +Y."}'
    - '// @input float theoryVectorScale = 0.85 {"hint":"Local scale for the real VectorField when staged in theory.", "widget":"slider", "min":0.35, "max":2, "step":0.05}'
    - '// @input vec3 gravityFrontOffset = {0,-28,-82} {"hint":"Camera-relative placement for gravity when reference calibration is disabled."}'
    - '// @input vec3 magneticFrontOffset = {0,0,-78} {"hint":"Camera-relative placement for magnetism when reference calibration is disabled."}'
    - '// @input vec3 windFrontOffset = {0,0,-78} {"hint":"Camera-relative placement for wind when reference calibration is disabled."}'
    - '// @input vec3 gravityReferenceOffset = {0,0,0} {"hint":"Gravity offset in calibrated plane-local space."}'
    - '// @input vec3 magneticReferenceOffset = {0,7,0} {"hint":"Magnetism offset in calibrated plane-local space."}'
    - '// @input vec3 windReferenceOffset = {0,24,0} {"hint":"Wind globe offset in calibrated plane-local space."}'
    - '// @input vec3 windGlobeMenuOffset = {0,10,-8} {"hint":"Menu-relative Earth Winds globe staging. X = menu right, Y = above original menu anchor, Z = menu normal; negative Z tucks behind the menu."}'
    - '// @input vec3 aerodynamicsMenuOffset = {0,-17.5,-2} {"hint":"Menu-relative Aerodynamics staging. X = menu right, Y = below the menu, Z = menu normal; negative Z tucks behind the menu."}'
    - '// @input float aerodynamicsMenuTiltDegrees {"hint":"Extra pitch for the menu-anchored aerodynamics field. Keep near zero when it should sit flush below the menu."}'
