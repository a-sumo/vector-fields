  InputLines:
    - '// @input float _lod = 1 {"hint":"Level of detail - affects radial segments, length segments, and grid size", "widget":"combobox", "values":[{"label":"Low", "value":0}, {"label":"Medium", "value":1}, {"label":"High", "value":2}, {"label":"Ultra", "value":3}]}'
    - '// @input float _maxVertexCount = 12000 {"hint":"Maximum vertex count budget - geometry adapts to stay below this (UInt16 max: 65535)", "widget":"slider", "min":8000, "max":65000, "step":1000}'
    - '// @input float _tubeMode {"hint":"Trails: flowing tubes, Particles: billboard tracers, Arrows: static oriented", "widget":"combobox", "values":[{"label":"Trails", "value":0}, {"label":"Particles", "value":1}, {"label":"Arrows", "value":2}]}'
    - '// @input float _desiredLengthSegments = 4 {"hint":"Desired segments along tube length (may be reduced to fit vertex budget)", "widget":"slider", "min":2, "max":64, "step":2}'
    - '// @input float _radius = 0.04 {"hint":"Tube radius", "widget":"slider", "min":0.01, "max":0.2, "step":0.01}'
    - '// @input float _coneLength = 4 {"hint":"Cone tip length multiplier for Arrow mode", "widget":"slider", "min":1, "max":30, "step":0.1}'
    - '// @input float _coneRadius = 1.7 {"hint":"Cone tip radius multiplier for Arrow mode", "widget":"slider", "min":1, "max":2.5, "step":0.1}'
    - '// @input float _arrowScale = 2 {"hint":"Arrow length scale factor (multiplied by field magnitude)", "widget":"slider", "min":0.5, "max":5, "step":0.1}'
    - '// @input float _gridSize = 5 {"hint":"Grid size (NxNxN)", "widget":"slider", "min":1, "max":10, "step":1}'
    - '// @input float _gridSpacing = 0.6 {"hint":"Spacing between tube start positions", "widget":"slider", "min":0.1, "max":5, "step":0.1}'
    - '// @input float _domainMode {"hint":"Where seeds are placed. Sphere Surface keeps the field on a globe-like shell.", "widget":"combobox", "values":[{"label":"Volume", "value":0}, {"label":"Sphere Surface", "value":1}, {"label":"Y-Normal Plane", "value":2}]}'
    - '// @input float _sphereRadius = 4.8 {"hint":"Radius for sphere surface fields", "widget":"slider", "min":1, "max":8, "step":0.1}'
    - '// @input float _planeWidth = 6.8 {"hint":"Width of the Y-normal ambient plane domain", "widget":"slider", "min":2, "max":12, "step":0.1}'
    - '// @input float _planeDepth = 4.05 {"hint":"Depth of the Y-normal ambient plane domain", "widget":"slider", "min":1, "max":8, "step":0.1}'
    - '// @input float _stepSize = 0.1 {"hint":"Step size for vector field integration", "widget":"slider", "min":0.01, "max":0.5, "step":0.01}'
    - '// @input float _fieldScale = 1 {"hint":"Field noise/frequency scale", "widget":"slider", "min":0.1, "max":3, "step":0.1}'
    - '// @input float _flowSpeed = 50 {"hint":"Speed at which tubes flow along field lines", "widget":"slider", "min":0, "max":100, "step":0.5}'
    - '// @input float _preset {"hint":"Vector field type", "widget":"combobox", "values":[{"label":"Burst", "value":0}, {"label":"Pull", "value":1}, {"label":"Orbit", "value":2}, {"label":"Waves", "value":3}, {"label":"Surface Wind", "value":8}, {"label":"Ambient Audio Plane", "value":9}]}'
    - '// @input float _colorMap = 18 {"hint":"Matplotlib-style colormap for speed/intensity.", "widget":"combobox", "values":[{"label":"jet", "value":13}, {"label":"viridis", "value":17}, {"label":"plasma", "value":18}]}'
    - '// @input float _colorMapScale = 1 {"hint":"Multiplies the normalized value before sampling the selected color gradient.", "widget":"slider", "min":0.05, "max":4, "step":0.01}'
    - '// @input float _colorMapOffset {"hint":"Adds to the normalized value before sampling the selected color gradient.", "widget":"slider", "min":-1, "max":1, "step":0.01}'
    - '// @input SceneObject trackedObject {"hint":"Object that affects the field - field reacts to its position"}'
    - '// @input Component.ColliderComponent fieldCollider {"hint":"Box collider - field only animates when tracked object is inside"}'
    - '// @input Asset.Material material {"hint":"Material with VectorFieldTubesShader.js"}'
