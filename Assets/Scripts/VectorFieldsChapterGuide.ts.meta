  InputLines:
    - '// @input SceneObject directorRoot {"hint":"Optional Story Step Director root. If empty, the script searches for it by name."}'
    - '// @input bool showOnStart = true {"hint":"Start visible and immediately stage the first chapter."}'
    - '// @input float initialIndex {"hint":"Initial chapter index for the main menu.", "widget":"slider", "min":0, "max":2, "step":1}'
    - '// @input bool controlContentRoots = true {"hint":"When no Story Step Director is present, enable the real content roots for each guide step."}'
    - '// @input bool isolateSceneInteractors = true {"hint":"While open, pause nearby scene colliders so content cannot steal menu touches."}'
    - '// @input vec3 panelOffset = {0,0,0} {"hint":"Offset from this root in centimeters."}'
    - '// @input SceneObject cameraRoot {"hint":"Optional head/camera anchor for Follow mode. Empty searches for Camera Object."}'
    - '// @input bool followUser {"hint":"Keep the menu in front of the user."}'
    - '// @input bool folded {"hint":"Start with only Fold/Open and Follow/Fixed controls visible."}'
    - '// @input float menuDistanceCm = 52 {"hint":"Distance from head anchor in centimeters when Follow is active."}'
    - '// @input float menuVisualScale = 1.55 {"hint":"Uniform visual scale for the entire menu plane and its hit targets.", "widget":"slider", "min":0.75, "max":2.5, "step":0.05}'
    - '// @input float menuVerticalOffsetCm = -7 {"hint":"Vertical offset from head anchor in centimeters when Follow is active."}'
    - '// @input float menuLowerOffsetCm = -14 {"hint":"Extra vertical drop so staged visuals can sit above the menu without calibration."}'
    - '// @input float weatherMenuDropCm = -28 {"hint":"Extra menu drop while Earth Winds is open, so the hand-distance globe can sit above the controls."}'
    - '// @input float analyticalMenuLiftCm = 26 {"hint":"Extra menu lift while analytical field patterns are open, leaving space below the menu for the manipulable field."}'
    - '// @input float weatherLayoutSmoothing = 8 {"hint":"Higher values make the Earth Winds layout offset blend in/out faster."}'
    - '// @input float menuHorizontalOffsetCm {"hint":"Horizontal offset from head anchor in centimeters when Follow is active."}'
    - "// @input float menuBillboardPitchBlend = 0.35 {\"hint\":\"How much Follow mode pitches the menu toward the user's head instead of yaw-only billboarding.\", \"widget\":\"slider\", \"min\":0, \"max\":1, \"step\":0.05}"
    - '// @input float followSmoothing = 9 {"hint":"Higher values make the menu catch up faster."}'
