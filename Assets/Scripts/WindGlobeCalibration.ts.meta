  InputLines:
    - '// @input SceneObject earthSphere {"hint":"Root SceneObject containing the Earth mesh. World position = sphere center."}'
    - '// @input SceneObject anchor {"hint":"Marker you drag onto a known landmark."}'
    - '// @input float anchorLat = 40.71 {"hint":"Anchor latitude (NYC = 40.71)."}'
    - '// @input float anchorLon = -74.01 {"hint":"Anchor longitude (NYC = -74.01)."}'
    - '// @input SceneObject verifier {"hint":"Verify marker — auto-positions at its lat/lon using the calibration."}'
    - '// @input float verifyLat = 51.51 {"hint":"Verifier latitude (London = 51.51)."}'
    - '// @input float verifyLon = -0.13 {"hint":"Verifier longitude (London = -0.13)."}'
    - '// @input float desiredRadiusWorld = 12 {"hint":"If > 0, rescale the Earth so its bbox radius matches this (cm). Otherwise leave natural size."}'
    - '// @input SceneObject legend {"hint":"Wind-speed widget. Pinned directly below the globe AABB so it keeps the same relative position and never orbits when the globe spins."}'
    - "// @input float legendGapCm = 8 {\"hint\":\"Gap (cm) between the bottom of the globe's AABB and the wind-speed widget.\"}"
    - '// @input SceneObject cameraRoot {"hint":"Optional head/camera anchor. Empty searches for Camera Object."}'
    - '// @input Asset.Material calloutMaterial {"hint":"Flat material used for selected weather-event callouts."}'
    - '// @input float eventFocusSeconds = 0.7 {"hint":"Seconds for an event focus rotation.", "widget":"slider", "min":0.2, "max":2, "step":0.05}'
    - '// @input float eventCalloutSurfaceLiftCm = 0.15 {"hint":"Small lift for selected weather-event callout anchor, in cm. Keep near zero so the dot remains on the true event location.", "widget":"slider", "min":0, "max":2, "step":0.05}'
    - '// @input float textureLongitudeOffsetDeg {"hint":"Manual longitude offset for the Earth texture, in degrees. Use if the map texture seam is not aligned to the default lat/lon convention.", "widget":"slider", "min":-180, "max":180, "step":1}'
    - '// @input bool invertLongitude {"hint":"Flip east/west longitude mapping for Earth textures with mirrored UV orientation."}'
